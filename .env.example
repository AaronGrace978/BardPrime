# ── BardPrime Configuration ──

# LLM Provider: deepseek | ollama | openai
LLM_PROVIDER=deepseek

# DeepSeek (default LLM for lyrics)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Or use generic LLM settings
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Ollama (local, free)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3

# ElevenLabs (for singing & music generation)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MUSIC_MODEL=music_v1

# Audio
# USE_GPU=false
